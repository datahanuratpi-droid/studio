
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isAgus() {
      return isSignedIn() && (request.auth.token.email == 'agus@hanura.id' || request.auth.token.email == 'agus');
    }

    function isAdmin() {
      return isSignedIn() && (exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)) || isAgus());
    }

    function isKSB() {
      return isSignedIn() && (exists(/databases/$(database)/documents/roles_ksb/$(request.auth.uid)) || isAdmin());
    }

    function isStaff() {
      return isSignedIn() && (exists(/databases/$(database)/documents/roles_staff/$(request.auth.uid)) || isKSB());
    }

    function isActive() {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status == 'Active';
    }

    // --- User Profiles ---
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
      allow delete: if isAdmin();
    }

    // --- Role Markers ---
    match /roles_admin/{userId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isAgus();
    }

    match /roles_ksb/{userId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /roles_staff/{userId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // --- Master Data Karyawan ---
    match /staff_members/{id} {
      allow read: if isStaff() && isActive();
      allow write: if isAdmin() && isActive();
    }

    // --- Common Access (Surat, Laporan, Kas) ---
    match /correspondences/{id} {
      allow read, write: if isStaff() && isActive();
    }

    match /activity_reports/{id} {
      allow read, write: if isStaff() && isActive();
    }

    match /financial_transactions/{id} {
      allow read, write: if isStaff() && isActive();
    }

    // --- Pustaka Hanura (Library) ---
    match /library_items/{id} {
      allow read: if isSignedIn() && isActive();
      allow write: if isAdmin() && isActive();
    }
  }
}
