rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CORE PHILOSOPHY
     * This ruleset enforces a multi-tier authorization model designed for office management. 
     * It leverages "Authorization Independence" by denormalizing ownership IDs (e.g., reporterId, 
     * createdByUserId) and using marker collections for high-performance role checks.
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)) ||
        request.auth.token.email == "agus@hanura.id"
      );
    }

    function isOfficer() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_officer/$(request.auth.uid));
    }

    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    // --- Collection Rules ---

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId);
      allow update: if resource != null && (isOwner(userId) || isAdmin());
      allow delete: if resource != null && isAdmin();
    }

    match /roles_admin/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      // Allow the designated super admin to create their own marker
      allow create: if isOwner(userId) && request.auth.token.email == "agus@hanura.id";
      allow update, delete: if isAdmin();
    }

    match /roles_officer/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /correspondences/{correspondenceId} {
      allow get, list: if isSignedIn() && (isAdmin() || isOfficer() || resource.data.createdByUserId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.createdByUserId == request.auth.uid;
      allow update: if resource != null && (isAdmin() || isExistingOwner(resource.data.createdByUserId));
      allow delete: if resource != null && (isAdmin() || isExistingOwner(resource.data.createdByUserId));
    }

    match /activity_reports/{activityReportId} {
      allow get, list: if isSignedIn() && (isAdmin() || isOfficer() || resource.data.reporterId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.reporterId == request.auth.uid;
      allow update: if resource != null && (isAdmin() || isExistingOwner(resource.data.reporterId)) && request.resource.data.reporterId == resource.data.reporterId;
      allow delete: if resource != null && (isAdmin() || isExistingOwner(resource.data.reporterId));
    }

    match /documents/{documentId} {
      allow get, list: if isSignedIn() && (isAdmin() || resource.data.accessScope == 'office_wide' || (resource.data.accessScope == 'personal' && resource.data.uploadedById == request.auth.uid));
      allow create: if isSignedIn() && request.resource.data.uploadedById == request.auth.uid;
      allow update: if resource != null && (isAdmin() || isExistingOwner(resource.data.uploadedById));
      allow delete: if resource != null && (isAdmin() || isExistingOwner(resource.data.uploadedById));
    }

    match /financial_categories/{categoryId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /financial_transactions/{transactionId} {
      allow get, list: if isSignedIn() && (isAdmin() || resource.data.recordedByUserId == request.auth.uid || resource.data.involvedPartyId == request.auth.uid);
      allow create: if (isAdmin() || isOfficer()) && request.resource.data.recordedByUserId == request.auth.uid;
      allow update: if resource != null && isAdmin();
      allow delete: if resource != null && isAdmin();
    }

    match /office_tasks/{taskId} {
      allow get, list: if isSignedIn() && (isAdmin() || resource.data.createdById == request.auth.uid || resource.data.assignedToUserId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.createdById == request.auth.uid;
      allow update: if resource != null && (isAdmin() || resource.data.createdById == request.auth.uid || resource.data.assignedToUserId == request.auth.uid);
      allow delete: if resource != null && (isAdmin() || isExistingOwner(resource.data.createdById));
    }
  }
}