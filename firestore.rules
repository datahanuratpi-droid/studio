
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isAgus() {
      return isSignedIn() && request.auth.token.email == 'agus@hanura.id';
    }

    function isAdmin() {
      return isSignedIn() && (exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)) || isAgus());
    }

    function isOfficer() {
      return isSignedIn() && (exists(/databases/$(database)/documents/roles_officer/$(request.auth.uid)) || isAdmin());
    }

    function isActive() {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status == 'Active';
    }

    // --- User Profiles ---
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
      allow delete: if isAdmin();
    }

    // --- Role Markers ---
    match /roles_admin/{userId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isAgus();
    }

    match /roles_officer/{userId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // --- Correspondences (Surat) ---
    match /correspondences/{id} {
      allow read: if isOfficer() && isActive();
      allow write: if isOfficer() && isActive();
    }

    // --- Activity Reports ---
    match /activity_reports/{id} {
      allow read: if isOfficer() && isActive();
      allow write: if isOfficer() && isActive();
    }

    // --- Financial Transactions (Kas) ---
    match /financial_transactions/{id} {
      allow read: if isOfficer() && isActive();
      allow write: if isOfficer() && isActive();
    }
  }
}
