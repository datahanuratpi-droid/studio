
{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "Represents a user's profile within the application.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "fullName": { "type": "string" },
        "role": { "type": "string", "enum": ["Admin", "KSB", "Staff"] },
        "status": { "type": "string", "enum": ["Pending Verification", "Active", "Inactive"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email", "fullName", "role", "status", "createdAt", "updatedAt"]
    },
    "Correspondence": {
      "title": "Correspondence",
      "description": "Represents incoming or outgoing mail.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "subject": { "type": "string" },
        "body": { "type": "string" },
        "type": { "type": "string", "enum": ["Incoming", "Outgoing"] },
        "correspondenceNumber": { "type": "string" },
        "correspondenceDate": { "type": "string", "format": "date-time" },
        "senderRecipientName": { "type": "string" },
        "status": { "type": "string" },
        "createdByUserId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["subject", "type", "correspondenceNumber", "correspondenceDate", "senderRecipientName", "status", "createdByUserId", "createdAt"]
    },
    "ActivityReport": {
      "title": "ActivityReport",
      "description": "Represents an activity report submitted by staff with specific attachments.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "location": { "type": "string" },
        "description": { "type": "string" },
        "reportDate": { "type": "string", "format": "date-time" },
        "reporterId": { "type": "string" },
        "status": { "type": "string" },
        "absensiFile": { "type": "string" },
        "spandukFile": { "type": "string" },
        "fotoBersamaFile": { "type": "string" },
        "fotoPendukungFile": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "location", "description", "reportDate", "reporterId", "status", "createdAt"]
    },
    "FinancialTransaction": {
      "title": "FinancialTransaction",
      "description": "Represents a cash transaction (receipt or payment).",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "amount": { "type": "number" },
        "transactionDate": { "type": "string", "format": "date-time" },
        "description": { "type": "string" },
        "type": { "type": "string" },
        "recordedByUserId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["amount", "transactionDate", "description", "type", "recordedByUserId", "createdAt"]
    },
    "DigitalArchive": {
      "title": "DigitalArchive",
      "description": "Represents a generic digital document archived in the system.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "archiveTitle": { "type": "string" },
        "fileName": { "type": "string" },
        "uploadedByUserId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["archiveTitle", "fileName", "uploadedByUserId", "createdAt"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile data."
    },
    "/correspondences/{id}": {
      "schema": "Correspondence",
      "description": "Store all mail records."
    },
    "/activity_reports/{id}": {
      "schema": "ActivityReport",
      "description": "Staff activity reports."
    },
    "/financial_transactions/{id}": {
      "schema": "FinancialTransaction",
      "description": "Cash flow records."
    },
    "/digital_archives/{id}": {
      "schema": "DigitalArchive",
      "description": "General digital archives."
    },
    "/roles_admin/{userId}": {
      "schema": { "type": "object", "properties": { "active": { "type": "boolean" } } },
      "description": "Marker for admin role."
    },
    "/roles_ksb/{userId}": {
      "schema": { "type": "object", "properties": { "active": { "type": "boolean" } } },
      "description": "Marker for KSB (Ketua, Sekretaris, Bendahara) role."
    },
    "/roles_staff/{userId}": {
      "schema": { "type": "object", "properties": { "active": { "type": "boolean" } } },
      "description": "Marker for Staff role."
    }
  }
}
