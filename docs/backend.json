
{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "Represents a user's profile within the application.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "fullName": { "type": "string" },
        "role": { "type": "string", "enum": ["Admin", "KSB", "Staff"] },
        "status": { "type": "string", "enum": ["Pending Verification", "Active", "Inactive"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email", "fullName", "role", "status", "createdAt", "updatedAt"]
    },
    "StaffMember": {
      "title": "StaffMember",
      "description": "Data detail karyawan untuk keperluan penggajian.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "fullName": { "type": "string" },
        "position": { "type": "string" },
        "baseSalary": { "type": "number" },
        "dailyRate": { "type": "number" },
        "bankName": { "type": "string" },
        "accountNumber": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["fullName", "position", "baseSalary", "createdAt"]
    },
    "Correspondence": {
      "title": "Correspondence",
      "description": "Represents incoming or outgoing mail.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "subject": { "type": "string" },
        "body": { "type": "string" },
        "type": { "type": "string", "enum": ["Incoming", "Outgoing"] },
        "correspondenceNumber": { "type": "string" },
        "correspondenceDate": { "type": "string", "format": "date-time" },
        "senderRecipientName": { "type": "string" },
        "status": { "type": "string" },
        "createdByUserId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["subject", "type", "correspondenceNumber", "correspondenceDate", "senderRecipientName", "status", "createdByUserId", "createdAt"]
    },
    "ActivityReport": {
      "title": "ActivityReport",
      "description": "Represents an activity report submitted by staff with specific attachments.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "location": { "type": "string" },
        "description": { "type": "string" },
        "reportDate": { "type": "string", "format": "date-time" },
        "reporterId": { "type": "string" },
        "status": { "type": "string" },
        "absensiFile": { "type": "string" },
        "spandukFile": { "type": "string" },
        "fotoBersamaFile": { "type": "string" },
        "fotoPendukungFiles": { 
          "type": "array",
          "items": { "type": "string" }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "location", "description", "reportDate", "reporterId", "status", "createdAt"]
    },
    "FinancialTransaction": {
      "title": "FinancialTransaction",
      "description": "Represents a cash transaction (receipt or payment).",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "amount": { "type": "number" },
        "transactionDate": { "type": "string", "format": "date-time" },
        "description": { "type": "string" },
        "type": { "type": "string" },
        "recordedByUserId": { "type": "string" },
        "involvedStaffId": { "type": "string" },
        "isClosed": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["amount", "transactionDate", "description", "type", "recordedByUserId", "createdAt"]
    },
    "LibraryItem": {
      "title": "LibraryItem",
      "description": "Represents a reference to a file stored in Google Drive.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "driveUrl": { "type": "string", "format": "uri" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "addedByUserId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "driveUrl", "addedByUserId", "createdAt"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile data."
    },
    "/staff_members/{id}": {
      "schema": "StaffMember",
      "description": "Master data karyawan."
    },
    "/correspondences/{id}": {
      "schema": "Correspondence",
      "description": "Store all mail records."
    },
    "/activity_reports/{id}": {
      "schema": "ActivityReport",
      "description": "Staff activity reports."
    },
    "/financial_transactions/{id}": {
      "schema": "FinancialTransaction",
      "description": "Cash flow records."
    },
    "/library_items/{id}": {
      "schema": "LibraryItem",
      "description": "Google Drive links and library resources."
    }
  }
}
